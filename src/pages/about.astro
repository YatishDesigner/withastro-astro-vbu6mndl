---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Yatish | The Engineer-Designer">
  
  <div class="bg-black min-h-screen pt-20 pb-24 text-white selection:bg-indigo-500/30">
    <section class="max-w-[1400px] mx-auto px-6 md:px-16">
      
      <div class="max-w-4xl mb-16 pt-12 md:pt-20">
        <h1 class="text-5xl md:text-[5.5rem] font-bold tracking-tighter mb-8 leading-[1.05]">
          <span class="text-[#86868b]">Less "Pixel Pusher."</span><br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-200 to-indigo-500">More Product Architect.</span>
        </h1>
        <p class="text-xl md:text-3xl text-[#86868b] font-medium tracking-tight leading-snug max-w-3xl">
          I bring a Computer Engineering background to UI/UX. I speak the language of developers, the strategy of C-suite, and the empathy of users.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-3 gap-6 h-auto md:min-h-[800px]">
        
        <div class="md:col-span-2 md:row-span-2 relative group rounded-[2rem] overflow-hidden bg-[#1d1d1f] border border-white/5 transition-all duration-500 min-h-[400px]">
          <img src="/images/about/workshop.png" alt="Yatish Facilitating Workshop" class="absolute inset-0 w-full h-full object-cover opacity-80 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100" />
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent"></div>
          
          <div class="absolute bottom-0 left-0 p-8 md:p-12 w-full">
            <div class="inline-block px-4 py-1.5 bg-indigo-600/20 border border-indigo-500/30 backdrop-blur-md text-indigo-400 text-xs font-bold uppercase tracking-widest rounded-full mb-4">
              Leadership
            </div>
            <h3 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">Facilitation over Dictation</h3>
            <p class="text-[#86868b] font-medium max-w-xl text-lg tracking-tight hidden md:block">
              My management style isn't about sitting in an office. It's about being at the whiteboard, untangling complexity with the team.
            </p>
            <p class="text-[#86868b] text-base tracking-tight md:hidden">
               Whiteboard leadership. Untangling complexity with the team.
            </p>
          </div>
        </div>

        <div class="aspect-[4/5] md:aspect-auto relative group rounded-[2rem] overflow-hidden bg-[#1d1d1f] border border-white/5 transition-all duration-500">
          <img src="/images/about/portrait.png" alt="Yatish Shirsath Portrait" class="absolute inset-0 w-full h-full object-cover grayscale opacity-70 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="absolute bottom-8 left-8 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out">
            <p class="text-white text-xl font-bold tracking-tight opacity-0 group-hover:opacity-100 transition-opacity duration-500">Stakeholder<br/>Management</p>
          </div>
        </div>

        <div class="bg-[#1d1d1f] rounded-[2rem] p-8 md:p-10 flex flex-col justify-center border border-white/5 hover:border-white/10 transition-colors relative overflow-hidden min-h-[200px] group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-indigo-500/10 rounded-full blur-3xl -z-10 group-hover:bg-indigo-500/20 transition-colors duration-500"></div>
          <h3 class="text-5xl md:text-6xl font-bold text-indigo-500 tracking-tighter mb-2">35%</h3>
          <p class="text-white text-xl font-bold tracking-tight mb-3">OpEx Reduction</p>
          <p class="text-[#86868b] font-medium tracking-tight leading-relaxed">
            Design isn't just art; it's economics. I focus on metrics that move the needle.
          </p>
        </div>

        <div class="rounded-[2rem] bg-[#1d1d1f] border border-white/5 p-8 md:p-10 flex flex-col justify-between overflow-hidden relative min-h-[200px] group hover:border-white/10 transition-colors">
          <svg class="absolute top-0 right-0 w-full h-full text-white opacity-5 group-hover:opacity-10 transition-opacity duration-500" viewBox="0 0 100 100" fill="none" stroke="currentColor">
            <path d="M10 90 Q 50 10 90 90" stroke-width="2" />
          </svg>
          <div class="relative z-10">
            <span class="text-xs font-bold text-red-500 uppercase tracking-widest">Fuel</span>
            <h3 class="text-2xl font-bold text-white tracking-tight mt-2">RedBull Racing Fan</h3>
          </div>
          <p class="text-[#86868b] font-medium tracking-tight mt-6 relative z-10">
            Precision, split-second decisions, and system optimization.
          </p>
        </div>

        <div class="md:col-span-2 bg-[#1d1d1f] rounded-[2rem] p-8 md:p-10 border border-white/5 flex items-center gap-8 hover:border-white/10 transition-colors min-h-[150px]">
          <div class="w-16 h-16 md:w-20 md:h-20 bg-orange-500/10 border border-orange-500/20 rounded-full flex items-center justify-center text-3xl flex-shrink-0">
            ☕️
          </div>
          <div>
            <h3 class="text-2xl font-bold text-white tracking-tight mb-2">Powered by Indian Chai</h3>
            <p class="text-[#86868b] text-lg font-medium tracking-tight">
              Exploration happens away from the screen.
            </p>
          </div>
        </div>

      </div>

      <div class="mt-32 mb-12 text-center">
        <h2 class="text-4xl md:text-5xl font-bold text-white tracking-tighter mb-8">Ready to optimize your design operations?</h2>
        <a href="mailto:yatish.designer@gmail.com" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-black transition-all duration-300 bg-white border border-transparent rounded-full hover:scale-105 hover:shadow-[0_0_30px_rgba(255,255,255,0.3)]">
          Let's Talk Strategy
        </a>
      </div>

    </section>
  </div>

</Layout>