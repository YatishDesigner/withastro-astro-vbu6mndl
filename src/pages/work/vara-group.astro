---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Vara Group: Scaling SaaS | Yatish Shirsath">
  
  <style>
    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(30px);
      transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-100 { transition-delay: 100ms; }
    .delay-200 { transition-delay: 200ms; }
    .delay-300 { transition-delay: 300ms; }
  </style>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.reveal-on-scroll').forEach((el) => observer.observe(el));
  </script>

  <div class="fixed top-0 left-0 h-1 bg-blue-500 z-50 w-full scale-x-0 animate-[progress_1s_ease-out_forwards] origin-left"></div>

  <header class="relative min-h-[90vh] flex flex-col justify-end p-6 md:p-12 overflow-hidden bg-black text-white">
    <div class="absolute inset-0 z-0 opacity-20 grayscale" 
         style="background-image: url('/images/vara-group/hero-bg.png'); background-size: cover; background-position: center;">
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent z-0"></div>
    
    <div class="relative z-10 max-w-[1400px] mx-auto w-full reveal-on-scroll">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-white/10 pb-8 mb-8">
        <div>
          <span class="font-mono text-xs tracking-[0.2em] uppercase mb-4 block text-[#86868b]">Case Study 03 • SaaS Platform</span>
          <h1 class="text-6xl md:text-[7rem] tracking-tighter leading-[0.9] text-white font-bold mb-2">
            Engineering<br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Efficiency.</span>
          </h1>
        </div>
        <div class="max-w-md flex flex-col items-start">
          <p class="text-lg md:text-xl leading-relaxed font-medium text-[#86868b] mb-6 tracking-tight">
            Digitizing the maintenance workflow for <strong class="text-white border-b border-white/30">Highway Toll Operations</strong>, replacing manual email loops with a real-time responsive ecosystem.
          </p>

          <a href="https://pm.varainfrovate.com/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-xs font-mono text-gray-400 hover:text-white transition-colors border-b border-transparent hover:border-white/50 pb-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
            <span>Live System Status: Active</span>
            <svg class="w-3 h-3 text-gray-500 group-hover:text-white ml-1 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
          </a>

        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 font-mono text-xs uppercase tracking-widest reveal-on-scroll delay-200">
        <div>
          <span class="block text-[#86868b] mb-1">Role</span>
          <span class="text-white font-bold">Lead UX Designer</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Impact</span>
          <span class="text-white font-bold">100% Digital Adoption</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Platform</span>
          <span class="text-white font-bold">Responsive Web App</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Timeline</span>
          <span class="text-white font-bold">20 Weeks</span>
        </div>
      </div>
    </div>
  </header>

  <section class="py-24 px-6 bg-[#111111]">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16">
        
        <div class="md:col-span-4 md:sticky md:top-32 h-fit reveal-on-scroll">
          <span class="font-mono text-xs text-blue-500 uppercase tracking-widest block mb-4">01 • The Problem</span>
          <h2 class="text-5xl md:text-6xl font-bold tracking-tighter leading-tight mb-6 text-white">
            The "Offline"<br/> <span class="text-[#86868b]">Bottleneck.</span>
          </h2>
          <p class="text-[#86868b] text-lg font-medium tracking-tight leading-relaxed mb-6">
            Engineers were maintaining critical highway hardware using a slow, manual process. Data was trapped in silos, leading to delays in fix-times across different regions of India.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white/5 border border-white/10 text-[10px] uppercase tracking-wider font-bold text-gray-300 rounded-full">Field Research</span>
            <span class="px-3 py-1 bg-white/5 border border-white/10 text-[10px] uppercase tracking-wider font-bold text-gray-300 rounded-full">User Personas</span>
          </div>
        </div>

        <div class="md:col-span-8 space-y-12">
          
          <div class="flex flex-col md:flex-row gap-6 border-t border-white/5 pt-8 reveal-on-scroll delay-100">
            <div class="w-12 text-3xl font-bold text-blue-500">A</div>
            <div>
              <h3 class="text-2xl font-bold mb-3 text-white tracking-tight">The "Photo-to-Email" Lag</h3>
              <p class="text-[#86868b] text-base mb-4 leading-relaxed font-medium">
                <strong class="text-white">The Workflow:</strong> Engineers took photos on site → Travelled back to office → Transferred to PC → Emailed Managers.
                <br/><br/>
                <strong class="text-white">The Pain:</strong> This feedback loop took hours, sometimes days. If a photo was blurry or data missing, they had to physically return to the toll station.
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row gap-6 border-t border-white/5 pt-8 reveal-on-scroll delay-200">
            <div class="w-12 text-3xl font-bold text-blue-500">B</div>
            <div>
              <h3 class="text-2xl font-bold mb-3 text-white tracking-tight">Managerial Blindspots</h3>
              <p class="text-[#86868b] text-base mb-4 leading-relaxed font-medium">
                <strong class="text-white">The Issue:</strong> No real-time visibility.
                <br/><br/>
                <strong class="text-white">The Pain:</strong> Managers were managing 100+ locations via Excel sheets. Assigning tasks was chaotic, and tracking "Open Tickets" vs "Resolved Tickets" was nearly impossible manually.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-black text-white relative overflow-hidden border-t border-white/5">
    <div class="absolute top-0 left-0 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-[1400px] mx-auto relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center reveal-on-scroll">
        
        <div>
          <span class="font-mono text-xs text-blue-500 uppercase tracking-widest block mb-4">02 • Strategic Pivot</span>
          <h2 class="text-5xl md:text-7xl font-bold tracking-tighter leading-tight mb-6 text-white">
            Agnostic <br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400">Accessibility.</span>
          </h2>
          <p class="text-[#86868b] text-lg font-medium tracking-tight leading-relaxed mb-8">
            <strong class="text-white">The Dilemma:</strong> The client wanted a Native App, but budget and device diversity were constraints.
            <br/><br/>
            <strong class="text-white">My Decision:</strong> I advocated for a <span class="text-white font-bold">Responsive Web Application (PWA)</span>. This ensured seamless access for field engineers on low-end Androids and managers on office Desktops, without the overhead of maintaining two codebases.
          </p>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="p-5 border border-white/10 rounded-2xl bg-[#1d1d1f]">
              <span class="block text-3xl font-bold text-white tracking-tighter mb-1">100%</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#86868b]">Device Coverage</span>
            </div>
            <div class="p-5 border border-white/10 rounded-2xl bg-[#1d1d1f]">
              <span class="block text-3xl font-bold text-white tracking-tighter mb-1">40%</span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-[#86868b]">Dev Time Saved</span>
            </div>
          </div>
        </div>

       <div class="relative h-[400px] bg-[#1d1d1f] rounded-[2rem] border border-white/10 overflow-hidden shadow-2xl group">
          <img src="/images/vara-group/pivot-abstract.png" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700" alt="Responsive Design Strategy" />
          
          <div class="absolute bottom-8 left-0 w-full text-center z-10">
              <p class="text-xs font-mono font-bold text-white bg-black/80 backdrop-blur-md inline-block px-5 py-2.5 rounded-full border border-white/20">Write Once. Run Everywhere.</p>
          </div>
       </div>

      </div>
    </div>
  </section>

  <section class="py-32 px-6 bg-[#111111]">
    <div class="max-w-[1400px] mx-auto">
      
      <div class="text-center mb-20 reveal-on-scroll">
        <h2 class="text-5xl md:text-7xl font-bold tracking-tighter text-white mb-6">The Dual Ecosystem.</h2>
        <p class="text-[#86868b] text-xl font-medium tracking-tight max-w-xl mx-auto">Two distinct interfaces sharing one brain. Tailored for the specific context of the user.</p>
      </div>

      <div class="space-y-32">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-24 items-center reveal-on-scroll delay-100">
          
          <div class="relative">
             <div class="aspect-video bg-[#1d1d1f] rounded-[2rem] shadow-2xl border border-white/10 p-2 flex items-center justify-center relative overflow-hidden group">
               <img src="/images/vara-group/mobile-pwa.png" class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100" alt="Mobile PWA Interface" />
             </div>
          </div>

          <div>
            <span class="text-blue-500 font-bold text-xs tracking-widest uppercase mb-4 block">For The Field Engineer</span>
            <h3 class="text-4xl font-bold text-white tracking-tight mb-6">Zero-Friction Reporting</h3>
            <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-8">
              We stripped the UI down to the essentials. Large touch targets for "Before/After" uploads, auto-filled location data via GPS, and offline capabilities ensured engineers could file reports in seconds, right from the toll booth.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center gap-4 text-base text-white font-medium">
                <div class="w-2.5 h-2.5 bg-green-500 rounded-full shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div> Real-time Image Upload
              </li>
              <li class="flex items-center gap-4 text-base text-white font-medium">
                <div class="w-2.5 h-2.5 bg-green-500 rounded-full shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div> Geotagged Validation
              </li>
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 md:gap-24 items-center reveal-on-scroll delay-200">
          
          <div class="order-2 lg:order-1">
            <span class="text-blue-500 font-bold text-xs tracking-widest uppercase mb-4 block">For The Manager</span>
            <h3 class="text-4xl font-bold text-white tracking-tight mb-6">The Command Center</h3>
            <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-8">
              A comprehensive dashboard giving a bird's-eye view of all highway assets. Managers can approve jobs, assign tickets to specific engineers, and view "Location-wise" health status of hardware instantly.
            </p>
            <ul class="space-y-4">
              <li class="flex items-center gap-4 text-base text-white font-medium">
                <div class="w-2.5 h-2.5 bg-blue-500 rounded-full shadow-[0_0_8px_rgba(59,130,246,0.6)]"></div> One-Click Approvals
              </li>
              <li class="flex items-center gap-4 text-base text-white font-medium">
                <div class="w-2.5 h-2.5 bg-blue-500 rounded-full shadow-[0_0_8px_rgba(59,130,246,0.6)]"></div> Asset Lifecycle Tracking
              </li>
            </ul>
          </div>

          <div class="order-1 lg:order-2 relative">
             <div class="aspect-video bg-[#1d1d1f] rounded-[2rem] shadow-2xl border border-white/10 p-2 flex items-center justify-center relative overflow-hidden group">
                <img src="/images/vara-group/desktop-dashboard.png" class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100" alt="Desktop Dashboard UI" />
             </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-black border-t border-white/5 text-white">
    <div class="max-w-[1400px] mx-auto">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 reveal-on-scroll">
        <div>
          <span class="font-mono text-xs text-gray-500 font-bold uppercase tracking-widest block mb-6">04 • Process</span>
          <h3 class="text-3xl font-bold tracking-tighter text-white mb-4">Crazy-8 to Code</h3>
          <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-8">
            We used <strong class="text-white">"Crazy-8" brainstorming sessions</strong> to rapidly iterate on the dashboard layout. The goal was to fit complex data (MAC IDs, Status, Location) into a card view that didn't feel overwhelming.
          </p>
          <div class="p-6 bg-[#1d1d1f] border border-white/5 rounded-2xl text-base font-medium text-[#86868b] italic leading-relaxed shadow-lg">
            "I learned the power of empathy in design—how understanding the daily workflow of engineers can lead to meaningful solutions."
          </div>
        </div>

        <div>
          <span class="font-mono text-xs text-gray-500 font-bold uppercase tracking-widest block mb-6">05 • Business Impact</span>
          <ul class="space-y-8">
            <li class="flex gap-6 items-start">
              <span class="text-5xl font-bold tracking-tighter text-blue-500 mt-1">1</span>
              <div>
                <h4 class="font-bold text-xl text-white tracking-tight mb-2">Reduced Turnaround Time</h4>
                <p class="text-base font-medium text-[#86868b] leading-relaxed">Real-time uploads eliminated the 24-hour reporting delay.</p>
              </div>
            </li>
            <li class="flex gap-6 items-start">
              <span class="text-5xl font-bold tracking-tighter text-blue-500 mt-1">2</span>
              <div>
                <h4 class="font-bold text-xl text-white tracking-tight mb-2">Cost Efficiency</h4>
                <p class="text-base font-medium text-[#86868b] leading-relaxed">Building a PWA saved ~40% dev budget compared to native Android/iOS apps.</p>
              </div>
            </li>
            <li class="flex gap-6 items-start">
              <span class="text-5xl font-bold tracking-tighter text-blue-500 mt-1">3</span>
              <div>
                <h4 class="font-bold text-xl text-white tracking-tight mb-2">Accountability</h4>
                <p class="text-base font-medium text-[#86868b] leading-relaxed">Geotagging features eliminated "fake visits," ensuring 100% compliance.</p>
              </div>
            </li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <div class="py-32 bg-[#111111] text-white text-center border-t border-white/5">
    <a href="/work/samoh" class="group inline-block">
      <span class="font-mono text-xs font-bold text-gray-500 uppercase tracking-widest mb-6 block group-hover:text-white transition-colors">Read Next Case Study</span>
      <h2 class="text-5xl md:text-7xl font-bold tracking-tighter text-[#86868b] group-hover:text-white transition-colors duration-500">
        Samoh: <br/> <span class="text-white">Luxury E-commerce</span>
      </h2>
    </a>
  </div>

</Layout>