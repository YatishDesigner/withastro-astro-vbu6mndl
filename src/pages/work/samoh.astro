---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Samoh: 0-to-1 Luxury Launch | Yatish Shirsath">
  
  <style>
    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(30px);
      transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .delay-100 { transition-delay: 100ms; }
    .delay-200 { transition-delay: 200ms; }
    .delay-300 { transition-delay: 300ms; }
  </style>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });

    document.querySelectorAll('.reveal-on-scroll').forEach((el) => observer.observe(el));
  </script>

  <div class="fixed top-0 left-0 h-1 bg-yellow-500 z-50 w-full scale-x-0 animate-[progress_1s_ease-out_forwards] origin-left"></div>

  <header class="relative min-h-[90vh] flex flex-col justify-end p-6 md:p-12 overflow-hidden bg-black text-white">
    <div class="absolute inset-0 z-0 opacity-40 grayscale" 
         style="background-image: url('/images/samoh/hero-bg.png'); background-size: cover; background-position: center;">
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent z-0"></div>
    
    <div class="relative z-10 max-w-[1400px] mx-auto w-full reveal-on-scroll">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 border-b border-white/10 pb-8 mb-8">
        <div>
          <span class="font-mono text-xs tracking-[0.2em] uppercase mb-4 block text-[#86868b]">Case Study 04 • 0-to-1 Launch</span>
          <h1 class="text-6xl md:text-[7rem] tracking-tighter leading-[0.9] text-white font-bold mb-2">
            The Digital<br/> <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-200 to-yellow-600">Atelier.</span>
          </h1>
        </div>
        <div class="max-w-md flex flex-col items-start">
          <p class="text-lg md:text-xl leading-relaxed font-medium text-[#86868b] mb-6 tracking-tight">
            Building a luxury ethnic wear brand from scratch. From the first whiteboard session to the <strong class="text-white border-b border-white/30">first live transaction</strong>.
          </p>

          <a href="https://www.samoh.in" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-xs font-mono text-gray-400 hover:text-white transition-colors border-b border-transparent hover:border-white/50 pb-0.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
            <span>Live System Status: Active</span>
            <svg class="w-3 h-3 text-gray-500 group-hover:text-white ml-1 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 font-mono text-xs uppercase tracking-widest reveal-on-scroll delay-200">
        <div>
          <span class="block text-[#86868b] mb-1">Role</span>
          <span class="text-white font-bold">Principal Designer</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Scope</span>
          <span class="text-white font-bold">End-to-End (0 to 1)</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Platform</span>
          <span class="text-white font-bold">Shopify Plus</span>
        </div>
        <div>
          <span class="block text-[#86868b] mb-1">Status</span>
          <span class="text-white font-bold">Live & Revenue Generating</span>
        </div>
      </div>
    </div>
  </header>

  <section class="py-24 px-6 bg-[#111111]">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-16">
        
        <div class="md:col-span-4 md:sticky md:top-32 h-fit reveal-on-scroll">
          <span class="font-mono text-xs text-yellow-500 uppercase tracking-widest block mb-4">01 • The Genesis</span>
          <h2 class="text-5xl md:text-6xl font-bold tracking-tighter leading-tight mb-6 text-white">
            Translating<br/> <span class="text-[#86868b]">Vision.</span>
          </h2>
          <p class="text-[#86868b] text-lg font-medium tracking-tight leading-relaxed mb-6">
            The business vision was clear: "Modern Indian Luxury." My challenge was to translate this abstract concept into a functional, conversion-optimized digital product.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white/5 border border-white/10 text-[10px] uppercase tracking-wider font-bold text-gray-300 rounded-full">Stakeholder Workshops</span>
            <span class="px-3 py-1 bg-white/5 border border-white/10 text-[10px] uppercase tracking-wider font-bold text-gray-300 rounded-full">Competitor Audit</span>
          </div>
        </div>

        <div class="md:col-span-8 space-y-12">
          
          <div class="flex flex-col md:flex-row gap-6 border-t border-white/5 pt-8 reveal-on-scroll delay-100">
            <div class="w-12 text-3xl font-bold text-yellow-500">A</div>
            <div>
              <h3 class="text-2xl font-bold mb-3 text-white tracking-tight">Defining the "Gold Standard"</h3>
              <p class="text-[#86868b] text-base mb-4 leading-relaxed font-medium">
                I sat down with the Business & Operations heads to deconstruct the brand DNA. We analyzed competitors (global luxury & indian ethnic) to identify gaps.
                <br/><br/>
                <strong class="text-white">The Insight:</strong> Competitors focused on "Catalogues." We needed to focus on "Collections." The site had to feel like a curated art gallery, not a warehouse.
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row gap-6 border-t border-white/5 pt-8 reveal-on-scroll delay-200">
            <div class="w-12 text-3xl font-bold text-yellow-500">B</div>
            <div>
              <h3 class="text-2xl font-bold mb-3 text-white tracking-tight">Shopify vs. Bespoke</h3>
              <p class="text-[#86868b] text-base leading-relaxed font-medium">
                We chose Shopify for stability but I pushed the platform's limits. I designed custom liquid templates to break the "cookie-cutter" Shopify look, ensuring the navigation and PDPs felt uniquely branded while retaining backend robustness.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-black border-t border-white/5"> 
    <div class="max-w-[1400px] mx-auto">
      <div class="mb-20 text-center reveal-on-scroll">
        <span class="font-mono text-xs text-yellow-500 uppercase tracking-widest block mb-4">02 • The Journey</span>
        <h2 class="text-5xl md:text-7xl font-bold tracking-tighter text-white mb-6">The "Happy Path"</h2>
        <p class="text-[#86868b] text-xl font-medium tracking-tight max-w-xl mx-auto">Designing a seamless flow from discovery to ownership.</p>
      </div>

      <div class="space-y-32">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center reveal-on-scroll delay-100">
          <div class="relative group">
             <div class="aspect-[3/4] bg-[#1d1d1f] shadow-2xl overflow-hidden relative border border-white/10 p-2 rounded-2xl">
                <img src="/images/samoh/discovery-home.png" class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100" alt="Samoh Homepage Design" />
             </div>
          </div>
          <div>
            <h3 class="text-4xl font-bold text-white tracking-tight mb-4">Visual Discovery</h3>
            <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-8">
              The Homepage isn't just banners; it's a mood board. I designed an intuitive navigation system that categorizes by "Occasion" (Wedding, cocktail, festive) rather than just "Kurtas" or "Sarees," aligning with the user's mental model.
            </p>
            <ul class="space-y-4 text-base font-medium text-white">
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-yellow-500 rounded-full shadow-[0_0_8px_rgba(234,179,8,0.6)]"></span> 
                Predictive Search
              </li>
              <li class="flex items-center gap-3">
                <span class="w-2 h-2 bg-yellow-500 rounded-full shadow-[0_0_8px_rgba(234,179,8,0.6)]"></span> 
                Mega-Menu Visuals
              </li>
            </ul>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center reveal-on-scroll delay-200">
          <div class="md:order-2 relative group">
             <div class="aspect-[3/4] bg-[#1d1d1f] shadow-2xl overflow-hidden relative border border-white/10 p-2 rounded-2xl">
                <img src="/images/samoh/purchase-pdp.png" class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 transition-opacity" alt="Samoh Product Page" />
                
                <div class="absolute bottom-0 left-0 w-full bg-[#111111]/90 backdrop-blur-md p-6 border-t border-white/10">
                  <div class="flex justify-between items-center mb-4 text-white">
                    <span class="text-xl font-bold tracking-tight">Silk Jamdani</span>
                    <span class="font-bold text-yellow-500">₹ 12,999</span>
                  </div>
                  <button class="w-full bg-white text-black font-bold py-3 text-xs uppercase tracking-widest rounded-lg hover:bg-gray-200 transition-colors">Add to Bag</button>
                </div>
             </div>
          </div>
          <div class="md:order-1">
            <h3 class="text-4xl font-bold text-white tracking-tight mb-4">Frictionless Luxury</h3>
            <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-6">
              The Product Detail Page (PDP) is the hero. I prioritized high-resolution zoom to show fabric texture. The "Add to Cart" sticky bar ensures conversion is never more than a thumb-tap away on mobile.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[#111111] border-t border-white/5">
    <div class="max-w-[1400px] mx-auto reveal-on-scroll">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 items-center">
        <div>
          <span class="font-mono text-xs text-yellow-500 uppercase tracking-widest block mb-4">03 • Retention</span>
          <h2 class="font-bold text-5xl md:text-6xl tracking-tighter text-white mb-6 leading-tight">
            Trust Beyond<br/> <span class="text-[#86868b]">The Checkout.</span>
          </h2>
          <p class="text-[#86868b] text-lg font-medium mb-10 leading-relaxed max-w-xl">
            Luxury isn't just buying; it's owning. I designed a comprehensive "My Account" ecosystem to reduce anxiety and build loyalty.
          </p>
          
          <ul class="space-y-8 max-w-xl">
            <li class="flex gap-6 items-start">
              <div class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-sm font-bold text-white shrink-0">1</div>
              <div>
                <strong class="block text-white text-xl tracking-tight mb-1">Granular Tracking</strong>
                <p class="text-base text-[#86868b] font-medium leading-relaxed">Visual timeline of order status (Processing, Stitching, Shipped).</p>
              </div>
            </li>
            <li class="flex gap-6 items-start">
              <div class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-sm font-bold text-white shrink-0">2</div>
              <div>
                <strong class="block text-white text-xl tracking-tight mb-1">Self-Serve Returns</strong>
                <p class="text-base text-[#86868b] font-medium leading-relaxed">One-tap cancellation and refund wallet integration.</p>
              </div>
            </li>
          </ul>
        </div>
        
        <div class="bg-[#1d1d1f] p-8 rounded-[2rem] border border-white/5 relative shadow-2xl">
          <div class="space-y-4">
            
            <div class="bg-[#2d2d2f] p-5 rounded-xl shadow-lg flex gap-4 items-center border border-white/5">
              <div class="w-14 h-14 bg-white/10 rounded-lg"></div>
              <div class="flex-1">
                <div class="h-2.5 w-32 bg-white/20 rounded-full mb-3"></div>
                <div class="h-2 w-20 bg-white/10 rounded-full"></div>
              </div>
              <span class="text-[10px] text-green-400 font-bold bg-green-500/10 border border-green-500/20 px-3 py-1.5 rounded-full tracking-wider">DELIVERED</span>
            </div>
            
            <div class="bg-[#2d2d2f] p-5 rounded-xl shadow-lg flex gap-4 items-center border border-white/5 opacity-60">
              <div class="w-14 h-14 bg-white/10 rounded-lg"></div>
              <div class="flex-1">
                <div class="h-2.5 w-32 bg-white/20 rounded-full mb-3"></div>
                <div class="h-2 w-20 bg-white/10 rounded-full"></div>
              </div>
              <span class="text-[10px] text-yellow-400 font-bold bg-yellow-500/10 border border-yellow-500/20 px-3 py-1.5 rounded-full tracking-wider">TRANSIT</span>
            </div>
            
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-black border-t border-white/5 text-white">
    <div class="max-w-[1400px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24 reveal-on-scroll">
        
        <div>
          <span class="font-mono text-xs text-yellow-500 font-bold uppercase tracking-widest block mb-6">04 • Leadership</span>
          <h3 class="text-4xl font-bold tracking-tighter text-white mb-6">"The Pixel Police"</h3>
          <p class="text-[#86868b] text-lg font-medium leading-relaxed mb-6">
            Designing it was half the battle. Building it right was the war. I led the QA (Quality Assurance) process, sitting with developers to fix padding, font-weights, and animation timings.
          </p>
          <p class="text-[#86868b] text-lg font-medium leading-relaxed">
            I managed the C-suite expectations, presenting weekly progress updates and justifying design decisions with competitive data, ensuring the vision remained undiluted.
          </p>
        </div>

        <div>
          <span class="font-mono text-xs text-yellow-500 font-bold uppercase tracking-widest block mb-6">05 • Business Impact</span>
          <ul class="space-y-8">
            <li class="flex gap-6 border-b border-white/10 pb-6">
              <span class="text-5xl font-bold tracking-tighter text-white">Live</span>
              <div>
                <h4 class="font-bold text-xl text-white tracking-tight">Revenue Generating</h4>
                <p class="text-sm font-medium text-[#86868b] mt-2 leading-relaxed">The site is live and processing orders daily.</p>
              </div>
            </li>
            <li class="flex gap-6 border-b border-white/10 pb-6">
              <span class="text-5xl font-bold tracking-tighter text-white">100%</span>
              <div>
                <h4 class="font-bold text-xl text-white tracking-tight">Vision Match</h4>
                <p class="text-sm font-medium text-[#86868b] mt-2 leading-relaxed">Zero compromise on the "Luxury" aesthetic during dev handoff.</p>
              </div>
            </li>
          </ul>
        </div>
        
      </div>
    </div>
  </section>

  <div class="py-32 bg-[#111111] text-white text-center border-t border-white/5">
    <a href="/work/westside" class="group inline-block">
      <span class="font-mono text-xs font-bold text-gray-500 uppercase tracking-widest mb-6 block group-hover:text-white transition-colors">Loop Back</span>
      <h2 class="text-5xl md:text-7xl font-bold tracking-tighter text-[#86868b] group-hover:text-white transition-colors duration-500">
        Return to <br/> <span class="text-white">Westside</span>
      </h2>
    </a>
  </div>

</Layout>