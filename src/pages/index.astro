---
import Layout from '../layouts/Layout.astro';

const brands = [
  { name: 'Westside', logo: '/images/brands/westside.svg' },
  { name: 'Samoh', logo: '/images/brands/samoh.svg' },
  { name: 'Trent', logo: '/images/brands/trent.svg' },
  { name: 'Luca Faloni', logo: '/images/brands/luca-faloni.svg' },
  { name: 'Vara Group', logo: '/images/brands/vara.svg' },
  { name: 'Global Logic', logo: '/images/brands/global-logic.svg' },
  { name: 'Altisource', logo: '/images/brands/altisource.svg' },
  { name: 'Burnt Toast', logo: '/images/brands/burnt-toast.svg' },
  { name: 'Brunel University', logo: '/images/brands/brunel.svg' },
];

const projects = [
  {
    title: "Omnichannel Strategy for TATA",
    client: "Westside",
    description: "Revamping the digital touchpoints for a premium fashion brand.",
    image: "/images/home/westside-thumb.png",
    link: "/work/westside"
  },
  {
    title: "Zero-to-Live Luxury Launch",
    client: "Samoh",
    description: "Owning the full UX roadmap and responsive architecture.",
    image: "/images/home/samoh-thumb.png",
    link: "/work/samoh"
  },
  {
    title: "Scaling SaaS for 100+ Engineers",
    client: "Vara Group",
    description: "Designing a complex device management platform.",
    image: "/images/home/vara-thumb.png",
    link: "/work/vara-group"
  }
];
---

<Layout title="Yatish Shirsath | UI-UX Design Lead">
  <style>
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-100%); }
    }
    .animate-scroll {
      /* Made slightly faster for smoother visual flow */
      animation: scroll 35s linear infinite;
    }
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>
    
    <div class="min-h-screen -mt-20 pt-20 transition-colors duration-300">
        
        <section class="relative min-h-[85vh] flex flex-col justify-end px-6 pb-24 md:px-16 md:pb-32 overflow-hidden">
            <div class="absolute top-1/4 right-1/4 w-[500px] h-[500px] bg-indigo-100/50 dark:bg-slate-800/40 rounded-full blur-[120px] -z-10 pointer-events-none transition-colors duration-500"></div>

            <div class="max-w-[1400px] w-full mx-auto relative z-10">
                <h2 class="text-xl md:text-3xl font-semibold mb-2 tracking-tight text-slate-500 dark:text-gray-400 transition-colors duration-300">UI-UX Design Lead</h2>
                <h1 class="text-5xl sm:text-6xl md:text-8xl font-bold tracking-tighter mb-4 text-slate-900 dark:text-white transition-colors duration-300">
                    Driving <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-600 dark:from-slate-200 dark:to-teal-600 transition-colors duration-300">Digital transformation.</span>
                </h1>
                <p class="text-xl sm:text-2xl md:text-3xl text-slate-600 dark:text-gray-400 font-medium max-w-3xl tracking-tight leading-snug transition-colors duration-300">
                    8+ years experience merging business strategy with user needs. Specialist in 0-to-1 launches.
                </p>

                <div class="grid grid-cols-2 md:grid-cols-3 gap-8 md:gap-16 pt-8 mt-12 max-w-4xl">
                    <div class="flex flex-col">
                        <span class="text-[2.5rem] md:text-[3.25rem] font-bold text-slate-900 dark:text-[#f5f5f7] tracking-tighter mb-1 transition-colors duration-300 leading-none">10+</span>
                        <span class="text-base md:text-lg text-slate-500 dark:text-[#86868b] font-medium tracking-tight transition-colors duration-300">Business Impacted</span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-[2.5rem] md:text-[3.25rem] font-bold text-slate-900 dark:text-[#f5f5f7] tracking-tighter mb-1 transition-colors duration-300 leading-none">100%</span>
                        <span class="text-base md:text-lg text-slate-500 dark:text-[#86868b] font-medium tracking-tight transition-colors duration-300">Stakeholder Approvals</span>
                    </div>
                    <div class="flex flex-col col-span-2 md:col-span-1">
                        <span class="text-[2.5rem] md:text-[3.25rem] font-bold text-slate-900 dark:text-[#f5f5f7] tracking-tighter mb-1 transition-colors duration-300 leading-none">1000+</span>
                        <span class="text-base md:text-lg text-slate-500 dark:text-[#86868b] font-medium tracking-tight transition-colors duration-300">Customers Served</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="work" class="py-24 px-6 md:px-16 bg-slate-50 dark:bg-black transition-colors duration-300 scroll-mt-20">
            <div class="max-w-[1400px] mx-auto">
                <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-12 gap-4">
                    <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-white tracking-tighter transition-colors duration-300">Get the highlights.</h2>
                    <p class="text-slate-500 dark:text-gray-400 text-lg md:text-xl font-medium tracking-tight transition-colors duration-300">Swipe to explore selected works.</p>
                </div>

                <div id="project-slider" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-8 -mx-6 px-6 md:-mx-16 md:px-16 scroll-smooth relative">
                    {projects.map((project, index) => (
                        <a href={project.link} data-index={index} class="project-card snap-center shrink-0 w-[85vw] md:w-[900px] aspect-[4/3] md:aspect-[16/9] bg-slate-200 dark:bg-[#1d1d1f] rounded-[2rem] overflow-hidden group relative flex flex-col cursor-pointer hover:shadow-2xl transition-all duration-500 border border-slate-200 dark:border-white/5 hover:border-slate-300 dark:hover:border-white/20">
                            
                            <div class="absolute inset-0 z-0 bg-black">
                                <img src={project.image} alt={project.title} class="object-cover w-full h-full group-hover:scale-[1.02] transition-transform duration-700 opacity-90 group-hover:opacity-100" />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
                            </div>
                            
                            <div class="relative z-10 mt-auto p-8 md:p-12">
                                <span class="inline-block px-4 py-1.5 bg-white/20 backdrop-blur-md text-white text-xs font-bold uppercase tracking-widest rounded-full mb-4">
                                    {project.client}
                                </span>
                                <h3 class="text-3xl md:text-5xl font-bold text-white mb-3 tracking-tight leading-tight">
                                    {project.title}
                                </h3>
                                <p class="text-gray-200 text-lg md:text-xl font-medium max-w-lg tracking-tight">
                                    {project.description}
                                </p>
                            </div>
                        </a>
                    ))}
                </div>

                <div class="flex items-center justify-end gap-3 mt-4 pr-0 md:pr-4">
                    <div class="flex items-center gap-3 bg-slate-200 dark:bg-[#2d2d2f] rounded-full px-5 py-3.5 transition-colors duration-300">
                        {projects.map((_, index) => (
                            <button 
                                class="dot-btn h-2 w-2 rounded-full bg-slate-400 dark:bg-[#86868b] transition-all duration-300 ease-out"
                                data-target={index}
                                aria-label={`Go to slide ${index + 1}`}
                            ></button>
                        ))}
                    </div>
                    
                    <button id="playPauseBtn" class="flex items-center justify-center w-[44px] h-[44px] bg-slate-200 dark:bg-[#2d2d2f] hover:bg-slate-300 dark:hover:bg-[#3d3d3f] rounded-full text-slate-700 dark:text-white transition-colors duration-300" aria-label="Pause Auto-scroll">
                        <svg id="pauseIcon" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/></svg>
                        <svg id="playIcon" class="w-5 h-5 hidden ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </button>
                </div>

            </div>
        </section>

        <section class="py-24 bg-slate-50 dark:bg-black overflow-hidden transition-colors duration-300">
            <div class="max-w-[1400px] mx-auto px-6 mb-16 text-center">
                <span class="font-mono text-sm text-slate-400 dark:text-[#86868b] uppercase tracking-[0.2em] font-bold transition-colors duration-300">Trusted By Market Leaders</span>
            </div>
            
            <div class="relative w-full overflow-hidden flex">
                <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-slate-50 dark:from-black to-transparent z-10 transition-colors duration-300"></div>
                <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-slate-50 dark:from-black to-transparent z-10 transition-colors duration-300"></div>

                <div class="flex w-max animate-scroll">
                    <div class="flex items-center justify-around gap-16 md:gap-24 px-12">
                        {brands.map((brand) => (
                            <img 
                                src={brand.logo} 
                                alt={brand.name} 
                                class="h-10 md:h-12 w-auto max-w-[160px] object-contain grayscale opacity-60 dark:invert dark:contrast-200 dark:opacity-100 transition-all duration-300" 
                            />
                        ))}
                    </div>
                    <div class="flex items-center justify-around gap-16 md:gap-24 px-12">
                        {brands.map((brand) => (
                            <img 
                                src={brand.logo} 
                                alt={brand.name} 
                                class="h-10 md:h-12 w-auto max-w-[160px] object-contain grayscale opacity-60 dark:invert dark:contrast-200 dark:opacity-100 transition-all duration-300" 
                            />
                        ))}
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('project-slider');
            const cards = document.querySelectorAll('.project-card');
            const dots = document.querySelectorAll('.dot-btn');
            const playPauseBtn = document.getElementById('playPauseBtn');
            const playIcon = document.getElementById('playIcon');
            const pauseIcon = document.getElementById('pauseIcon');

            let isPlaying = true;
            let autoScrollInterval;
            let currentIndex = 0;
            const scrollDelay = 3500; 

            const updateDots = (activeIndex) => {
                currentIndex = parseInt(activeIndex);
                dots.forEach((dot, index) => {
                    if (index === currentIndex) {
                        dot.classList.remove('w-2', 'bg-slate-400', 'dark:bg-[#86868b]');
                        dot.classList.add('w-6', 'bg-slate-800', 'dark:bg-[#f5f5f7]');
                    } else {
                        dot.classList.add('w-2', 'bg-slate-400', 'dark:bg-[#86868b]');
                        dot.classList.remove('w-6', 'bg-slate-800', 'dark:bg-[#f5f5f7]');
                    }
                });
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        updateDots(entry.target.dataset.index);
                    }
                });
            }, {
                root: slider,
                threshold: 0.6 
            });

            cards.forEach(card => observer.observe(card));

            const scrollToSlide = (index) => {
                if(cards[index]) {
                    const card = cards[index];
                    const scrollPosition = card.offsetLeft - slider.offsetLeft - (slider.clientWidth / 2) + (card.clientWidth / 2);
                    
                    slider.scrollTo({
                        left: scrollPosition,
                        behavior: 'smooth'
                    });
                }
            };

            const nextSlide = () => {
                let nextIndex = currentIndex + 1;
                if (nextIndex >= cards.length) nextIndex = 0;
                scrollToSlide(nextIndex);
            };

            const startAutoScroll = () => {
                if (isPlaying) {
                    clearInterval(autoScrollInterval);
                    autoScrollInterval = setInterval(nextSlide, scrollDelay);
                }
            };

            const stopAutoScroll = () => {
                clearInterval(autoScrollInterval);
            };

            playPauseBtn.addEventListener('click', () => {
                isPlaying = !isPlaying;
                if (isPlaying) {
                    playIcon.classList.add('hidden');
                    pauseIcon.classList.remove('hidden');
                    startAutoScroll();
                } else {
                    playIcon.classList.remove('hidden');
                    pauseIcon.classList.add('hidden');
                    stopAutoScroll();
                }
            });

            dots.forEach((dot) => {
                dot.addEventListener('click', (e) => {
                    const targetIndex = e.target.dataset.target;
                    scrollToSlide(targetIndex);
                    stopAutoScroll();
                    startAutoScroll();
                });
            });

            slider.addEventListener('pointerdown', stopAutoScroll);
            slider.addEventListener('pointerup', startAutoScroll);
            slider.addEventListener('touchstart', stopAutoScroll, {passive: true});
            slider.addEventListener('touchend', startAutoScroll);

            startAutoScroll();
            updateDots(0);
        });
    </script>
</Layout>