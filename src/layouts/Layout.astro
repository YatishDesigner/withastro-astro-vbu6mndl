---
import '../styles/global.css'
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Yatish Shirsath - Strategic Design Manager" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<title>{title}</title>
		<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-CS0643C17V"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-CS0643C17V');
</script>
	</head>
	
    <body class="bg-black text-white font-sans antialiased selection:bg-teal-900 selection:text-teal-100">
		
		<nav class="fixed top-0 w-full bg-black/80 backdrop-blur-md z-50 border-b border-white/10">
			<div class="max-w-[1400px] mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/" class="text-lg font-bold tracking-tight hover:text-teal-400 transition-colors text-white">
					Yatish
				</a>
				
                <div class="flex items-center gap-6 text-sm font-medium text-gray-300">
                    <div class="flex gap-8">
                        {['Work', 'About', 'Contact'].map((item) => (
                            <a 
                                href={
                                    item === 'Contact' ? '#footer' : 
                                    item === 'Work' ? '/#work' : 
                                    `/${item.toLowerCase()}`
                                } 
                                class="relative group py-1"
                            >
                                <span class="group-hover:text-white transition-colors">{item}</span>
                            </a>
                        ))}
                    </div>
				</div>
			</div>
		</nav>

		<main class="min-h-screen pt-20">
			<slot />
		</main>

		<footer id="footer" class="bg-[#111111] border-t border-white/5 mt-20 pb-16">
			<div class="max-w-[1400px] mx-auto px-6 pt-16">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-12">
					
					<div>
						<h3 class="text-3xl font-bold mb-4 text-white tracking-tight">Let's build something scalable.</h3>
						<p class="text-gray-400 mb-8 max-w-md text-lg leading-relaxed">
							Open to discussing design strategy, 0 to 1 scale, and digital transformation.
						</p>
						<a href="mailto:yatish.designer@gmail.com" class="text-lg font-bold text-teal-400 hover:text-teal-300 transition-colors">
							yatish.designer@gmail.com
						</a>
					</div>

					<div class="flex flex-col md:items-end gap-6 justify-between">
					    
					    <div class="flex flex-col md:items-end gap-4 mt-2 md:mt-0">
    						<span class="text-gray-500 text-xs uppercase tracking-[0.2em] font-bold">Connect</span>
    						
    						<div class="flex gap-3">
    						    
    						    <a href="https://www.linkedin.com/in/yatish-shirsath" target="_blank" aria-label="LinkedIn" class="group flex items-center h-12 w-12 hover:w-[130px] bg-white/5 hover:bg-[#0a66c2] border border-white/5 hover:border-transparent rounded-full text-white transition-all duration-300 ease-out overflow-hidden">
    						        <div class="flex items-center justify-center min-w-[3rem] h-12">
    						            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
    						        </div>
                                    <span class="whitespace-nowrap font-medium text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-75 pr-4">
                                        LinkedIn
                                    </span>
    						    </a>
    
    						    <a href="#" target="_blank" aria-label="Behance" class="group flex items-center h-12 w-12 hover:w-[125px] bg-white/5 hover:bg-[#1769ff] border border-white/5 hover:border-transparent rounded-full text-white transition-all duration-300 ease-out overflow-hidden">
    						        <div class="flex items-center justify-center min-w-[3rem] h-12">
    						            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14h-8.027c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h4.965c-.105-1.547-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988h-6.466v-16h5.397c2.93 0 5.633.981 5.633 4.364 0 2.39-1.536 3.868-3.111 4.296 2.067.265 3.514 1.756 3.514 3.98 0 2.92-2.146 3.36-4.967 3.36zm-2.466-7.512h-4v4.512h4c1.92 0 2.871-.525 2.871-2.256 0-1.723-.976-2.256-2.871-2.256zm-4-4.5h3.764c1.697 0 2.471-.689 2.471-2.046 0-1.517-1.041-1.954-2.508-1.954h-3.727v4z"/></svg>
    						        </div>
                                    <span class="whitespace-nowrap font-medium text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-75 pr-4">
                                        Behance
                                    </span>
    						    </a>
    
    						    <a href="#" target="_blank" aria-label="Dribbble" class="group flex items-center h-12 w-12 hover:w-[125px] bg-white/5 hover:bg-[#ea4c89] border border-white/5 hover:border-transparent rounded-full text-white transition-all duration-300 ease-out overflow-hidden">
    						        <div class="flex items-center justify-center min-w-[3rem] h-12">
    						            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 24c6.627 0 12-5.373 12-12s-5.373-12-12-12-12 5.373-12 12 5.373 12 12 12zm6.591-15.556c-3.667 1.924-5.355 3.39-6.858 5.313 2.48 2.503 5.203 3.176 6.704 3.253.308-1.039.49-2.13.513-3.272-.116-.174-.235-.348-.359-.524-.001-.001-.001 0 0 0zm-1.803-1.53c-1.311.045-2.735.344-4.14 1.164-1.309-1.294-2.274-3.08-2.611-4.786 1.848-.303 3.738-.28 5.234.195.553 1.056 1.066 2.193 1.517 3.427zm-7.668-3.327c.451 1.787 1.488 3.512 2.87 4.77-1.74 1.636-4.045 2.544-6.392 2.379.13-2.997 1.635-5.698 3.522-7.149zm-4.755 8.914c2.516.324 4.965-.63 6.852-2.308.887 1.127 1.621 2.385 2.152 3.743-2.585.877-5.91 1.054-8.156.402.164-1.488.164-1.071-.848-1.837zm9.648 3.917c-.571-1.428-1.332-2.753-2.261-3.929 2.107-.936 4.779-1.318 7.339-1.026.046.368.08.742.08 1.122 0 3.321-1.353 6.326-3.526 8.455-.494-1.72-1.036-3.155-1.632-4.622z"/></svg>
    						        </div>
                                    <span class="whitespace-nowrap font-medium text-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 delay-75 pr-4">
                                        Dribbble
                                    </span>
    						    </a>
    						    
    						</div>
						</div>
						
						<p class="text-gray-500 text-sm md:mt-16">© 2026 Yatish Shirsath. Vibe-coded.</p>
					</div>

				</div>
			</div>
		</footer>
	</body>
</html>